{% doc %}
  Brand Colors

  Outputs CSS custom properties for the full AquaTru brand color system.
  Includes Tailwind-scale color palettes and primary palette aliases.

  @example {% render 'brand-colors' %}
{% enddoc %}

{% style %}
  :root {
    /* Primary Palette Aliases */
    --brand-tru-teal: #00839F;
    --brand-light-turquoise: #45BCD1;
    --brand-deep-teal: #2E5C6C;
    --brand-calm-teal: #C7E8ED;
    --brand-active-blue: #48B8F0;
    --brand-clear-blue: #D4E4FA;
    --brand-ideal-orange: #F9A31A;

    /* Teel Scale */
    --brand-teel-50: #EBF5F4;
    --brand-teel-100: #C7E8ED;
    --brand-teel-200: #81D8E5;
    --brand-teel-300: #45BCD1;
    --brand-teel-400: #159AB2;
    --brand-teel-500: #00839F;
    --brand-teel-600: #2E5C6C;
    --brand-teel-700: #0C424D;
    --brand-teel-800: #102D33;
    --brand-teel-900: #0F181A;

    /* Aqua Scale */
    --brand-aqua-50: #EBF3F7;
    --brand-aqua-100: #C9E7F5;
    --brand-aqua-200: #8BD3F7;
    --brand-aqua-300: #48B8F0;
    --brand-aqua-400: #1195D6;
    --brand-aqua-500: #0073BA;
    --brand-aqua-600: #08548A;
    --brand-aqua-700: #0E3D66;
    --brand-aqua-800: #0C2B45;
    --brand-aqua-900: #0B1724;

    /* Blue Scale */
    --brand-blue-50: #F0F4FA;
    --brand-blue-100: #D4E4FA;
    --brand-blue-200: #ADCCF7;
    --brand-blue-300: #75B1FF;
    --brand-blue-400: #3D8DF5;
    --brand-blue-500: #186ADE;
    --brand-blue-600: #0D4EA6;
    --brand-blue-700: #103A75;
    --brand-blue-800: #11294D;
    --brand-blue-900: #0D1826;

    /* Orange Scale */
    --brand-orange-50: #FEF5E5;
    --brand-orange-100: #FCE8CC;
    --brand-orange-200: #F9D298;
    --brand-orange-300: #F8B866;
    --brand-orange-400: #F9A31A;
    --brand-orange-500: #F38B00;
    --brand-orange-600: #AB6300;
    --brand-orange-700: #794600;
    --brand-orange-800: #472A00;
    --brand-orange-900: #311C01;

    /* Green Scale */
    --brand-green-50: #EBF7ED;
    --brand-green-100: #C7EBD1;
    --brand-green-200: #88DBA8;
    --brand-green-300: #43C478;
    --brand-green-400: #16A163;
    --brand-green-500: #077D55;
    --brand-green-600: #075E45;
    --brand-green-700: #094536;
    --brand-green-800: #092E25;
    --brand-green-900: #081A15;

    /* Red Scale */
    --brand-red-50: #FCF3F2;
    --brand-red-100: #FADCD9;
    --brand-red-200: #FABBB4;
    --brand-red-300: #FC9086;
    --brand-red-400: #FA5343;
    --brand-red-500: #D91F11;
    --brand-red-600: #A1160A;
    --brand-red-700: #75160C;
    --brand-red-800: #4F150F;
    --brand-red-900: #24120C;

    /* Neutral Scale */
    --brand-neutral-50: #FFFFFF;
    --brand-neutral-100: #F8F7F3;
    --brand-neutral-200: #F1F0EC;
    --brand-neutral-300: #E7E6E2;
    --brand-neutral-400: #D4D3CF;
    --brand-neutral-500: #C8C8C6;
    --brand-neutral-600: #B6B5B2;
    --brand-neutral-700: #767676;
    --brand-neutral-800: #484847;
  }
{% endstyle %}
