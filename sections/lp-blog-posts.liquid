{% liquid
  assign max_posts = section.settings.post_limit
  assign blog = section.settings.blog
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    lp-blog-posts
    spacing-style
  "
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    --lp-bp-bg: {{ section.settings.background_color }};
    --lp-bp-heading-color: {{ section.settings.heading_color }};
  "
>
  {% if section.settings.heading != blank %}
    <div class="lp-blog-posts__heading">{{ section.settings.heading }}</div>
  {% endif %}

  <div class="lp-blog-posts__grid">
    {% if blog != blank and blog.articles_count > 0 %}
      {% for article in blog.articles limit: max_posts %}
        <article class="lp-blog-posts__card">
          {% if article.image != blank %}
            <a href="{{ article.url }}" class="lp-blog-posts__card-image-link">
              <img
                src="{{ article.image | image_url: width: 640 }}"
                alt="{{ article.image.alt | default: article.title | escape }}"
                width="320"
                height="200"
                loading="lazy"
                class="lp-blog-posts__image"
              >
            </a>
          {% endif %}

          <div class="lp-blog-posts__card-content">
            <h3 class="lp-blog-posts__title">
              <a href="{{ article.url }}">{{ article.title | escape }}</a>
            </h3>

            {% if article.excerpt_or_content != blank %}
              <p class="lp-blog-posts__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            {% endif %}

            <span class="lp-blog-posts__date">{{ article.published_at | date: '%B %d, %Y' }}</span>
          </div>
        </article>
      {% endfor %}
    {% else %}
      {% for i in (1..4) %}
        <article class="lp-blog-posts__card">
          <div class="lp-blog-posts__card-image-link">
            <div class="lp-blog-posts__image-placeholder"></div>
          </div>
          <div class="lp-blog-posts__card-content">
            <h3 class="lp-blog-posts__title">
              <a href="#">Sample Post {{ i }}</a>
            </h3>
            <p class="lp-blog-posts__excerpt">This is a sample blog post excerpt for placeholder content.</p>
          </div>
        </article>
      {% endfor %}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .lp-blog-posts {
    display: flex;
    flex-direction: column;
    gap: 24px;
    background-color: var(--lp-bp-bg, #FFFFFF);
  }

  .lp-blog-posts__heading {
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-size: var(--font-size--3xl, 2rem);
    line-height: 40px;
    color: var(--lp-bp-heading-color, var(--brand-teel-800, #102D33));
    margin: 0;
  }

  .lp-blog-posts__heading p {
    margin: 0;
  }

  .lp-blog-posts__grid {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding-block-end: 8px;
  }

  .lp-blog-posts__grid::-webkit-scrollbar {
    display: none;
  }

  .lp-blog-posts__card {
    flex: 0 0 280px;
    min-width: 260px;
    max-width: 300px;
    border-radius: 6px;
    overflow: hidden;
    background: #FFFFFF;
    display: flex;
    flex-direction: column;
    scroll-snap-align: start;
    border: 1px solid var(--color-border, #E7E6E2);
  }

  .lp-blog-posts__card-image-link {
    display: block;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--color-border, #eee);
  }

  .lp-blog-posts__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lp-blog-posts__image-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-border, #eee);
  }

  .lp-blog-posts__card-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px;
  }

  .lp-blog-posts__title {
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-size: var(--font-size--lg, 1.125rem);
    line-height: 28px;
    color: var(--brand-teel-800, #102D33);
    margin: 0;
  }

  .lp-blog-posts__title a {
    text-decoration: none;
    color: inherit;
  }

  .lp-blog-posts__title a:hover {
    text-decoration: underline;
  }

  .lp-blog-posts__excerpt {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: var(--font-size--sm, 0.875rem);
    line-height: 20px;
    color: var(--color-foreground, #121211);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .lp-blog-posts__date {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: 12px;
    line-height: 16px;
    color: var(--color-foreground, #121211);
    opacity: 0.6;
  }

  @media screen and (min-width: 769px) {
    .lp-blog-posts__grid {
      overflow-x: visible;
      flex-wrap: wrap;
    }

    .lp-blog-posts__card {
      flex: 1 1 calc(25% - 12px);
      max-width: calc(25% - 12px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.lp_blog_posts",
  "tag": "section",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "t:settings.blog"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "<p>Recommended Posts</p>"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "t:settings.max_products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "t:content.colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:settings.heading_color",
      "default": "#102D33"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "t:names.lp_blog_posts"
    }
  ]
}
{% endschema %}
