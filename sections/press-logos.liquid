<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    press-logos
    spacing-style
  "
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    --press-logos-bg: {{ section.settings.background_color }};
    --press-logos-text-color: {{ section.settings.text_color }};
    --press-logos-speed: {{ section.settings.speed }}s;
  "
>
  {% if section.settings.heading != blank %}
    <h2 class="press-logos__heading">{{ section.settings.heading | escape }}</h2>
  {% endif %}

  <div class="press-logos__track" {% if section.settings.auto_scroll %}data-auto-scroll{% endif %}>
    <div class="press-logos__list">
      {% for block in section.blocks %}
        {% if block.type == 'logo' %}
          <div class="press-logos__item" {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="press-logos__link" aria-label="{{ block.settings.alt_text | default: 'Press logo' | escape }}">
            {% endif %}

            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 300 }}"
                alt="{{ block.settings.alt_text | default: '' | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
                class="press-logos__image"
                style="max-height: {{ block.settings.max_height }}px;"
              >
            {% elsif block.settings.svg_asset != blank %}
              <img
                src="{{ block.settings.svg_asset | asset_url }}"
                alt="{{ block.settings.alt_text | default: '' | escape }}"
                loading="lazy"
                class="press-logos__image"
                style="max-height: {{ block.settings.max_height }}px;"
              >
            {% else %}
              <div class="press-logos__placeholder" style="width: 120px; height: 32px; background: var(--color-border, #ccc); border-radius: 4px;"></div>
            {% endif %}

            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.auto_scroll %}
      <div class="press-logos__list" aria-hidden="true">
        {% for block in section.blocks %}
          {% if block.type == 'logo' %}
            <div class="press-logos__item">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 300 }}"
                  alt=""
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  loading="lazy"
                  class="press-logos__image"
                  style="max-height: {{ block.settings.max_height }}px;"
                >
              {% elsif block.settings.svg_asset != blank %}
                <img
                  src="{{ block.settings.svg_asset | asset_url }}"
                  alt=""
                  loading="lazy"
                  class="press-logos__image"
                  style="max-height: {{ block.settings.max_height }}px;"
                >
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .press-logos {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    background-color: var(--press-logos-bg, var(--brand-calm-teal, #C7E8ED));
  }

  .press-logos__heading {
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-size: var(--font-size--lg, 1.125rem);
    line-height: 28px;
    color: var(--press-logos-text-color, var(--brand-aqua-800, #0C2B45));
    text-align: center;
    margin: 0;
  }

  .press-logos__track {
    display: flex;
    overflow: hidden;
    width: 100%;
  }

  .press-logos__track[data-auto-scroll] {
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .press-logos__track[data-auto-scroll] .press-logos__list {
    animation: press-logos-scroll var(--press-logos-speed, 20s) linear infinite;
    flex-shrink: 0;
  }

  .press-logos__list {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .press-logos__item {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 240px;
    height: 40px;
    flex-shrink: 0;
  }

  .press-logos__link {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .press-logos__image {
    display: block;
    width: auto;
    height: auto;
    max-height: 32px;
    object-fit: contain;
  }

  @keyframes press-logos-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-100% - 16px));
    }
  }

  @media screen and (max-width: 768px) {
    .press-logos__track:not([data-auto-scroll]) {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    .press-logos__track:not([data-auto-scroll])::-webkit-scrollbar {
      display: none;
    }

    .press-logos__item {
      scroll-snap-align: center;
      min-width: 180px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .press-logos__track[data-auto-scroll] .press-logos__list {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.press_logos",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Featured In"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "#C7E8ED"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text_color",
      "default": "#0C2B45"
    },
    {
      "type": "checkbox",
      "id": "auto_scroll",
      "label": "t:settings.auto_rotate_slides",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "label": "t:settings.speed",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 20,
      "unit": "s"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "full-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "t:names.logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:settings.image"
        },
        {
          "type": "text",
          "id": "svg_asset",
          "label": "t:settings.svg_asset_filename",
          "info": "e.g. bf-wordmark-red.svg"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "t:settings.alt_text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:settings.link"
        },
        {
          "type": "range",
          "id": "max_height",
          "label": "t:settings.max_height",
          "min": 16,
          "max": 60,
          "step": 2,
          "default": 32,
          "unit": "px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:names.press_logos",
      "blocks": [
        { "type": "logo", "settings": { "svg_asset": "bf-wordmark-red.svg", "alt_text": "BuzzFeed" } },
        { "type": "logo", "settings": { "svg_asset": "gooponlinelogo-1.svg", "alt_text": "Goop" } },
        { "type": "logo", "settings": { "svg_asset": "good-housekeeping-seeklogo-1.svg", "alt_text": "Good Housekeeping" } },
        { "type": "logo", "settings": { "svg_asset": "business-insider-2023-logo-1.svg", "alt_text": "Business Insider" } },
        { "type": "logo", "settings": { "svg_asset": "layer-1.svg", "alt_text": "Allure" } },
        { "type": "logo", "settings": { "svg_asset": "new-york-magazine-logo-1.svg", "alt_text": "New York Magazine" } }
      ]
    }
  ]
}
{% endschema %}
