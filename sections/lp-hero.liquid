<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    lp-hero
    spacing-style
  "
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    --lp-hero-overlay-color: {{ section.settings.overlay_color }};
  "
>
  <div class="lp-hero__background">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: section.settings.image.width
        | image_tag:
          sizes: '100vw',
          widths: '375,750,1100,1500,2000',
          loading: 'eager',
          fetchpriority: 'high',
          class: 'lp-hero__bg-image',
          alt: section.settings.image.alt
      }}
    {% else %}
      <div class="lp-hero__bg-placeholder"></div>
    {% endif %}
    <div class="lp-hero__overlay"></div>
  </div>

  <div class="lp-hero__content">
    {% if section.settings.heading != blank %}
      <h1 class="lp-hero__heading">{{ section.settings.heading | escape }}</h1>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="lp-hero__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a
        href="{{ section.settings.button_link | default: '#' }}"
        class="lp-hero__button"
      >
        {{ section.settings.button_text | escape }}
      </a>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .lp-hero {
    position: relative;
    min-height: 600px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .lp-hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .lp-hero__bg-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lp-hero__bg-placeholder {
    width: 100%;
    height: 100%;
    background: #102D33;
  }

  .lp-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(16, 45, 51, 0.85) 0%,
      rgba(16, 45, 51, 0.4) 50%,
      rgba(16, 45, 51, 0.1) 100%
    );
  }

  .lp-hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 48px 16px;
    width: 100%;
    max-width: 700px;
  }

  .lp-hero__heading {
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-size: var(--font-size--4xl, 2.5rem);
    line-height: 1.1;
    color: #FFFFFF;
    margin: 0;
  }

  .lp-hero__subheading {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: var(--font-size--base, 1rem);
    line-height: 24px;
    color: #FFFFFF;
    margin: 0;
  }

  .lp-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: 28px;
    background: var(--brand-ideal-orange, #F9A31A);
    border: none;
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: var(--font-size--base, 1rem);
    line-height: 24px;
    color: var(--brand-aqua-900, #311C01);
    text-decoration: none;
    cursor: pointer;
    text-align: center;
    width: fit-content;
  }

  .lp-hero__button:hover {
    opacity: 0.9;
  }

  @media screen and (min-width: 769px) {
    .lp-hero {
      min-height: 720px;
    }

    .lp-hero__content {
      padding: 80px 48px;
    }

    .lp-hero__heading {
      font-size: var(--font-size--5xl, 3rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-hero__button:hover {
      opacity: 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.lp_hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Water You Can Trust. Results You Can Taste."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:settings.subheading",
      "default": "AquaTru removes what most filters miss - Forever Chemicals (PFOA/PFOS), Microplastics, Lead, and more."
    },
    {
      "type": "header",
      "content": "t:content.buttons"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:settings.button_label",
      "default": "Shop Water Purifiers"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:settings.link"
    },
    {
      "type": "header",
      "content": "t:content.colors"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:settings.overlay_color",
      "default": "#102D33"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-6"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "full-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 56,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "t:names.lp_hero"
    }
  ]
}
{% endschema %}
