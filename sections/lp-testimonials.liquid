<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<lp-testimonials
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    lp-testimonials
    spacing-style
  "
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    --lp-tst-bg: {{ section.settings.background_color }};
    --lp-tst-heading-color: {{ section.settings.heading_color }};
  "
>
  <div class="lp-testimonials__header">
    {% if section.settings.star_image != blank or section.settings.star_svg != blank %}
      <div class="lp-testimonials__rating-row">
        {% if section.settings.star_image != blank %}
          <img
            src="{{ section.settings.star_image | image_url: width: 172 }}"
            alt="Rating stars"
            width="86"
            height="14"
            loading="lazy"
          >
        {% elsif section.settings.star_svg != blank %}
          <img
            src="{{ section.settings.star_svg | asset_url }}"
            alt="Rating stars"
            width="86"
            height="14"
            loading="lazy"
          >
        {% endif %}
        {% if section.settings.rating_text != blank %}
          <span class="lp-testimonials__rating-text">{{ section.settings.rating_text | escape }}</span>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <div class="lp-testimonials__heading">{{ section.settings.heading }}</div>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="lp-testimonials__carousel">
      <div class="lp-testimonials__track">
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
            <div class="lp-testimonials__card" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                <div class="lp-testimonials__card-image">
                  <img
                    src="{{ block.settings.image | image_url: width: 640 }}"
                    alt="{{ block.settings.author_name | default: 'Customer' | escape }}"
                    width="320"
                    height="256"
                    loading="lazy"
                    class="lp-testimonials__image"
                  >
                </div>
              {% endif %}

              <div class="lp-testimonials__card-content">
                {% if block.settings.quote != blank %}
                  <blockquote class="lp-testimonials__quote">{{ block.settings.quote | escape }}</blockquote>
                {% endif %}

                <div class="lp-testimonials__author">
                  <div class="lp-testimonials__avatar">
                    {{ block.settings.author_initials | default: 'AB' | escape }}
                  </div>
                  <div class="lp-testimonials__author-info">
                    {% if block.settings.author_name != blank %}
                      <span class="lp-testimonials__author-name">{{ block.settings.author_name | escape }}</span>
                    {% endif %}
                    {% if block.settings.verified %}
                      <span class="lp-testimonials__verified">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                          <circle cx="6" cy="6" r="6" fill="#446835"/>
                          <path d="M3.5 6L5.5 8L8.5 4.5" stroke="#FFFFFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span>{{ block.settings.verified_label | default: 'Verified User' | escape }}</span>
                      </span>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</lp-testimonials>

{% stylesheet %}
  .lp-testimonials {
    display: flex;
    flex-direction: column;
    gap: 24px;
    background-color: var(--lp-tst-bg, var(--brand-calm-teal, #C7E8ED));
    overflow: hidden;
  }

  .lp-testimonials__header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .lp-testimonials__rating-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .lp-testimonials__rating-text {
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: var(--font-size--base, 1rem);
    line-height: 24px;
    color: var(--brand-aqua-800, #0C2B45);
  }

  .lp-testimonials__heading {
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-size: var(--font-size--3xl, 2rem);
    line-height: 40px;
    color: var(--lp-tst-heading-color, var(--brand-teel-800, #102D33));
    margin: 0;
  }

  .lp-testimonials__heading p {
    margin: 0;
  }

  .lp-testimonials__carousel {
    overflow: visible;
  }

  .lp-testimonials__track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding-block-end: 8px;
  }

  .lp-testimonials__track::-webkit-scrollbar {
    display: none;
  }

  .lp-testimonials__card {
    flex: 0 0 320px;
    min-width: 280px;
    max-width: 320px;
    border-radius: 6px;
    overflow: hidden;
    background: #FFFFFF;
    display: flex;
    flex-direction: column;
    scroll-snap-align: start;
  }

  .lp-testimonials__card-image {
    height: 256px;
    overflow: hidden;
    background: #FFFFFF;
  }

  .lp-testimonials__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lp-testimonials__card-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 16px;
  }

  .lp-testimonials__quote {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: var(--font-size--base, 1rem);
    line-height: 24px;
    color: var(--brand-teel-800, #102D33);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .lp-testimonials__author {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .lp-testimonials__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #E7E6E2;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: 12px;
    line-height: 16px;
    color: #121211;
    flex-shrink: 0;
  }

  .lp-testimonials__author-info {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  .lp-testimonials__author-name {
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 14px;
    line-height: 20px;
    color: #121211;
  }

  .lp-testimonials__verified {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: 12px;
    line-height: 16px;
    color: #446835;
  }

  @media screen and (min-width: 769px) {
    .lp-testimonials__track {
      overflow-x: visible;
      flex-wrap: wrap;
    }

    .lp-testimonials__card {
      flex: 1 1 calc(33.333% - 11px);
      max-width: calc(33.333% - 11px);
    }
  }
{% endstylesheet %}

{% javascript %}
  import '@theme/lp-testimonials';
{% endjavascript %}

{% schema %}
{
  "name": "t:names.lp_testimonials",
  "tag": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "<p>Customers love our award-winning products</p>"
    },
    {
      "type": "image_picker",
      "id": "star_image",
      "label": "t:settings.star_rating_image"
    },
    {
      "type": "text",
      "id": "star_svg",
      "label": "t:settings.star_svg_asset",
      "default": "rating-star.svg"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "t:settings.rating_text",
      "default": "Over 300,000+ 5 Star Reviews"
    },
    {
      "type": "header",
      "content": "t:content.colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "#C7E8ED"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:settings.heading_color",
      "default": "#102D33"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:names.testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:settings.image"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:settings.quote",
          "default": "\"I love this so much. The water tastes amazing. After buying my first one, I bought another for my son and his family. Everyone raves about the quality and clean water.\""
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "t:settings.author_name",
          "default": "Elizabeth M."
        },
        {
          "type": "text",
          "id": "author_initials",
          "label": "t:settings.author_initials",
          "default": "EM"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "t:settings.verified_user",
          "default": true
        },
        {
          "type": "text",
          "id": "verified_label",
          "label": "t:settings.verified_label",
          "default": "Verified User"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:names.lp_testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "\"I love this so much. The water tastes amazing. After buying my first one, I bought another for my son and his family. Everyone raves about the quality and clean water.\"",
            "author_name": "Elizabeth M.",
